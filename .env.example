# ============================================
# Horizon Trader Platform — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# --- PostgreSQL Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=horizon
POSTGRES_USER=horizon_user
POSTGRES_PASSWORD=your_database_password_here

# Database connection string (used by frontend and bot)
DATABASE_URL=postgresql://horizon_user:your_database_password_here@db:5432/horizon

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_ID=your_telegram_group_id_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook/telegram

# --- Cloudflare R2 Object Storage ---
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=horizon-media
R2_PUBLIC_URL=https://your-r2-public-url.com

# --- Admin Credentials (initial seed) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# --- Application ---
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com
BOT_PORT=4000
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Nginx / SSL ---
DOMAIN=yourdomain.com
SSL_EMAIL=your_email@example.com
